# Mentat Web Application Environment Variables

# API Backend URL
VITE_API_URL=http://localhost:8000

# App Configuration
VITE_APP_NAME=Mentat Protocol
VITE_APP_ENV=development

# Solana Network Configuration
# Options: mainnet-beta | testnet | devnet | localnet
# This controls which network the app connects to
VITE_SOLANA_NETWORK=devnet

# Optional: Custom RPC URL (overrides the default cluster URL)
# Uncomment and set to use a custom RPC endpoint
# VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
# VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# VITE_SOLANA_RPC_URL=http://localhost:8899
